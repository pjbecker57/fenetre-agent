# Airtable
AIRTABLE_TOKEN=your_airtable_token
AIRTABLE_BASE_ID=your_base_id
AIRTABLE_TABLE_CATALOGUE=your_table_id
AIRTABLE_TABLE_ENTREPRISE=your_table_id
AIRTABLE_TABLE_LEADS=your_table_id
AIRTABLE_TABLE_CONVERSATIONS=your_table_id
AIRTABLE_TABLE_FAQ=your_table_id

# OpenAI (optionnel — mode démo si absent)
OPENAI_API_KEY=sk-xxx

# Twilio WhatsApp (optionnel)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Twilio PRO (numéro artisan — peut être le même que le client en dev)
TWILIO_PRO_WHATSAPP_NUMBER=whatsapp:+14155238886
PRO_ARTISAN_NUMBERS=+33612345678,+33698765432

# SendGrid Email (optionnel — pour envoi du résumé par email)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=contact@votre-entreprise.fr

# Port
PORT=3000
